MODELFIT_ENV=development
MODELFIT_LOG_LEVEL=INFO

MODELFIT_API_HOST=0.0.0.0
MODELFIT_API_PORT=8000
MODELFIT_API_BASE_URL=http://localhost:8000

MODELFIT_POSTGRES_DB=modelfit
MODELFIT_POSTGRES_USER=modelfit
MODELFIT_POSTGRES_PASSWORD=change-me
MODELFIT_DATABASE_URL=postgresql+asyncpg://modelfit:change-me@localhost:5432/modelfit

MODELFIT_REDIS_URL=redis://localhost:6379/0

MODELFIT_MINIO_ENDPOINT=localhost:9000
MODELFIT_MINIO_ACCESS_KEY=modelfit
MODELFIT_MINIO_SECRET_KEY=change-me-now
MODELFIT_MINIO_SECURE=false
MODELFIT_MINIO_BUCKET=modelfit

MODELFIT_MLFLOW_TRACKING_URI=http://localhost:5000

MODELFIT_GEMMA_LICENSE_ACCEPTED=false
MODELFIT_DEFAULT_CANDIDATE_MODELS=phi_4_mini,qwen3_8b

MODELFIT_MCP_DOCUMENT_URL=http://localhost:9101/mcp
MODELFIT_MCP_IMAGE_URL=http://localhost:9102/mcp
MODELFIT_MCP_WEB_URL=http://localhost:9103/mcp
MODELFIT_MCP_REQUIRE_TOOL_APPROVAL=true
MODELFIT_MCP_ALLOWED_SERVERS=document,image,web
